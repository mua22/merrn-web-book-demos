<div class="container">
    <h1 class="mb-4">Our Products</h1>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        <% products.forEach(product => { %>
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="<%= product.image %>" class="card-img-top" alt="<%= product.name %>" style="height: 200px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title"><%= product.name %></h5>
                        <h6 class="card-subtitle mb-2 text-muted"><%= product.category ? product.category.name : 'Uncategorized' %></h6>
                        <p class="card-text text-primary fw-bold fs-5 mt-2">$<%= product.price.toFixed(2) %></p>
                        <button class="btn btn-outline-primary mt-auto add-to-cart-btn" data-product-name="<%= product.name %>">Add to Cart</button>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>
