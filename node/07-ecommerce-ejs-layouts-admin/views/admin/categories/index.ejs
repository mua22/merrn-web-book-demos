<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h2>Categories</h2>
    <a href="/admin/categories/add" class="btn btn-primary">Add Category</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% categories.forEach(category => { %>
            <tr>
                <td><%= category.name %></td>
                <td>
                    <a href="/admin/categories/edit/<%= category._id %>" class="btn btn-sm btn-warning">Edit</a>
                    <form action="/admin/categories/delete/<%= category._id %>" method="POST" class="d-inline" onsubmit="return confirm('Are you sure?');">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        <% }) %>
        <% if (categories.length === 0) { %>
            <tr>
                <td colspan="2" class="text-center">No categories found.</td>
            </tr>
        <% } %>
    </tbody>
</table>
