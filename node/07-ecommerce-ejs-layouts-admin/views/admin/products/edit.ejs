<div class="pt-3 pb-2 mb-3 border-bottom">
    <h2>Edit Product</h2>
</div>

<form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data" class="mt-4" style="max-width: 500px;">
    <div class="mb-3">
        <label for="name" class="form-label">Product Name</label>
        <input type="text" class="form-control" id="name" name="name" value="<%= product.name %>" required>
    </div>
    
    <div class="mb-3">
        <label for="price" class="form-label">Price</label>
        <input type="number" step="0.01" class="form-control" id="price" name="price" value="<%= product.price %>" required>
    </div>

    <div class="mb-3">
        <label for="category" class="form-label">Category</label>
        <select class="form-select" id="category" name="category" required>
            <% categories.forEach(category => { %>
                <option value="<%= category._id %>" <%= (product.category && product.category.toString() === category._id.toString()) ? 'selected' : '' %>>
                    <%= category.name %>
                </option>
            <% }) %>
        </select>
    </div>

    <div class="mb-3">
        <label for="image" class="form-label">Product Image (Leave empty to keep current)</label>
        <input class="form-control" type="file" id="image" name="image" accept="image/*">
        
        <% if (product.image) { %>
            <div class="mt-2">
                <p>Current Image:</p>
                <img src="<%= product.image %>" alt="<%= product.name %>" width="100">
            </div>
        <% } %>
    </div>

    <button type="submit" class="btn btn-primary">Update Product</button>
    <a href="/admin/products" class="btn btn-secondary">Cancel</a>
</form>
